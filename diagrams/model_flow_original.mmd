flowchart TD
    A["输入数据<br/>split_x.csv + label.csv"] --> B["MultiModalFeatureDataset<br/>读取 slide_id"]
    B --> C1["图像特征<br/>image_dir/slide_id.pt<br/>[n, 512]"]
    B --> C2["文本特征<br/>text_dir/case_id.pt<br/>[N, 512]"]
    B --> C3["标签 y<br/>仅 source/train 有监督"]

    C1 --> D1["SharedMapper<br/>共享映射网络"]
    C2 --> D2["SharedMapper<br/>共享映射网络"]

    D1 --> E1["AttentionPooling<br/>图像序列池化"]
    D2 --> E2["AttentionPooling<br/>文本序列池化"]

    E1 --> F1["img_vec [B, D]"]
    E2 --> F2["txt_vec [B, D]"]

    F1 --> G["MoEFusion 路由融合"]
    F2 --> G

    G --> G1["Expert 1<br/>Concat + Self-Attention"]
    G --> G2["Expert 2<br/>Add + Self-Attention"]
    G --> G3["Expert 3<br/>Cross-Attention"]
    G1 --> H["Router 加权求和"]
    G2 --> H
    G3 --> H

    H --> I["fused feature [B, D]"]
    I --> J["StageClassifier"]
    J --> K["logits / probs / preds"]

    C3 --> L["分类损失 CrossEntropy<br/>loss_cls"]
    K --> L

    D1 --> M1["source 图像 patch mapped features"]
    D1 --> M2["target 图像 patch mapped features"]
    M1 --> N1["build_graph_features<br/>KMeans 节点 + TopK 构图 + hop topology"]
    M2 --> N2["build_graph_features<br/>KMeans 节点 + TopK 构图 + hop topology"]

    N1 --> O1["node features"]
    N2 --> O2["node features"]
    N1 --> P1["topology features"]
    N2 --> P2["topology features"]

    O1 --> Q1["MMD<br/>loss_node"]
    O2 --> Q1
    P1 --> Q2["MMD<br/>loss_topo"]
    P2 --> Q2

    D2 --> R1["source 文本 mapped features 求均值"]
    D2 --> R2["target 文本 mapped features 求均值"]
    R1 --> Q3["MMD<br/>loss_txt"]
    R2 --> Q3

    L --> S["总损失"]
    Q1 --> S
    Q2 --> S
    Q3 --> S

    S --> T["loss = loss_cls + decay * (alpha*loss_txt + beta*loss_node + gamma*loss_topo)"]
